{
  "expo": {
    "name": "MessOptimize",
    "slug": "messoptimize",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "messoptimize",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#233D4D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.messoptimize.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#233D4D"
      },
      "package": "com.messoptimize.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-sharing"
    ]
  }
}
